# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?appName=YourApp

# NextAuth configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-random-32-char-string

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Groq API key (https://console.groq.com/keys)
GROQ_API_KEY=gsk-your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Gmail SMTP for OTP + welcome emails (use a Google App Password)
APP_EMAIL=your@gmail.com
APP_PASSWORD=your-gmail-app-password
APP_NAME=ProposalAI

# Public site / legal pages (set in Vercel Production)
NEXT_PUBLIC_APP_URL=https://your-production-domain.com
NEXT_PUBLIC_LEGAL_ENTITY_NAME=Your Legal Name or Company
NEXT_PUBLIC_LEGAL_CONTACT_EMAIL=support@yourdomain.com

# Google AdSense (safe to commit — public client/slot IDs)
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-9021169824928895
NEXT_PUBLIC_ADSENSE_SLOT=6672025564
